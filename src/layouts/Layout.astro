---
import "../styles/global.css";
import DinosaurIcon from "../assets/icons/dinosaur.svg";
import SpaceInvaderIcon from "../assets/icons/space-invader.svg";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.png" />
        <meta name="generator" content={Astro.generator} />
        <title>Riley Draward</title>
    </head>
    <body>
        <div
            id="theme-switcher"
            class="theme-switcher"
            role="group"
            aria-label="Theme"
        >
            <button
                class="theme-option theme-option-dinosaur"
                type="button"
                data-theme-option="light"
                aria-label="Dinosaur theme"
                aria-pressed="false"
            >
                <DinosaurIcon class="theme-icon" />
            </button>
            <button
                class="theme-option theme-option-invader"
                type="button"
                data-theme-option="dark"
                aria-label="Space invader theme"
                aria-pressed="false"
            >
                <SpaceInvaderIcon class="theme-icon" />
            </button>
        </div>

        <slot />

        <style>
            .theme-switcher {
                position: absolute;
                right: 0.5rem;
                top: 0.5rem;
                z-index: 4;
                display: flex;
                align-items: center;
                padding: 0.1875rem;
                border: 2px solid var(--dinosaur-color);
                background: rgba(244, 239, 226, 0.88);
                box-shadow: 0 4px 0 rgba(210, 4, 45, 0.12);
            }

            :global(.dark) .theme-switcher {
                border-color: var(--space-invader-color);
                background: rgba(8, 13, 21, 0.9);
                box-shadow: 0 4px 0 rgba(163, 230, 53, 0.1);
            }

            .theme-option {
                display: grid;
                place-items: center;
                width: 2.25rem;
                height: 2.25rem;
                padding: 0;
                color: rgb(71 85 105);
                background: transparent;
                border: 0;
                cursor: pointer;
                opacity: 0.72;
                transition:
                    color 160ms ease,
                    background-color 160ms ease,
                    opacity 160ms ease;
            }

            .theme-option:hover,
            .theme-option:focus-visible {
                opacity: 1;
            }

            .theme-option:focus-visible {
                outline: 2px solid currentColor;
                outline-offset: 2px;
            }

            .theme-option[aria-pressed="true"] {
                color: var(--dinosaur-color);
                background: rgba(210, 4, 45, 0.14);
                opacity: 1;
            }

            .theme-icon {
                width: 1.25rem;
                height: 1.25rem;
            }

            :global(.dark) .theme-option {
                color: rgb(148 163 184);
            }

            :global(.dark) .theme-option[aria-pressed="true"] {
                color: var(--space-invader-color);
                background: rgba(163, 230, 53, 0.16);
            }
        </style>

        <script is:inline>
            function syncThemeSwitcher() {
                const html = document.documentElement;
                const activeTheme = html.classList.contains("dark")
                    ? "dark"
                    : "light";

                document
                    .querySelectorAll("[data-theme-option]")
                    .forEach((option) => {
                        option.setAttribute(
                            "aria-pressed",
                            option.dataset.themeOption === activeTheme
                                ? "true"
                                : "false",
                        );
                    });
            }

            function setTheme(theme) {
                const html = document.documentElement;

                if (theme === "dark") {
                    html.classList.add("dark");
                } else {
                    html.classList.remove("dark");
                }

                localStorage.setItem("theme", theme);
                syncThemeSwitcher();
            }

            function initTheme() {
                const html = document.documentElement;

                const savedTheme = localStorage.getItem("theme");
                const systemPrefersDark = window.matchMedia(
                    "(prefers-color-scheme: dark)",
                ).matches;

                if (
                    savedTheme === "dark" ||
                    (!savedTheme && systemPrefersDark)
                ) {
                    html.classList.add("dark");
                }
            }

            function setupThemeToggle() {
                document
                    .querySelectorAll("[data-theme-option]")
                    .forEach((option) => {
                        option.addEventListener("click", () => {
                            setTheme(option.dataset.themeOption);
                        });
                    });

                syncThemeSwitcher();
            }

            initTheme();

            if (document.readyState === "loading") {
                document.addEventListener("DOMContentLoaded", setupThemeToggle);
            } else {
                setupThemeToggle();
            }
        </script>
    </body>
</html>
