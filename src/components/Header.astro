---
interface Props {
    subtext: string;
}

const { subtext } = Astro.props;
---

<header class="site-header">
    <div class="site-title">
        <h1 class="type-display">RILEY DRAWARD</h1>
        <p class="type-subtitle">{subtext}</p>
    </div>
    <div class="site-actions">
        <slot />
    </div>
    <div class="site-page-nav">
        <slot name="page-nav" />
    </div>
</header>

<style>
    .site-header {
        --site-panel-light: rgba(244, 239, 226, 0.88);
        --site-panel-dark: rgba(8, 13, 21, 0.9);
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        min-height: 5.5rem;
        padding: 0.8rem 6.25rem 0.8rem 1rem;
        border-bottom: 4px solid var(--dinosaur-color);
        background: var(--site-panel-light);
        box-shadow: 0 8px 0 rgba(210, 4, 45, 0.12);
    }

    :global(.dark) .site-header {
        border-bottom-color: var(--space-invader-color);
        background: var(--site-panel-dark);
        box-shadow: 0 8px 0 rgba(163, 230, 53, 0.1);
    }

    .site-title {
        min-width: 0;
    }

    .site-title h1 {
        margin: 0;
    }

    .site-title p {
        margin: 0.45rem 0 0;
    }

    /* Header actions line up with the fixed theme switcher. */
    .site-actions {
        --header-control-height: 2.875rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        align-self: flex-start;
        flex-shrink: 0;
        height: var(--header-control-height);
        margin-top: -0.3rem;
    }

    .site-page-nav {
        position: absolute;
        top: 3.85rem;
        right: 0.5rem;
        z-index: 3;
        display: flex;
        justify-content: flex-end;
    }

    @media (max-width: 720px) {
        .site-header {
            display: grid;
            grid-template-columns: minmax(0, 1fr);
            gap: 0.6rem;
            padding: 0.7rem 5.75rem 0.65rem 0.65rem;
        }

        .site-actions {
            justify-content: space-between;
            width: 100%;
            gap: 0.5rem;
            margin-top: -0.2rem;
        }

        .site-page-nav {
            position: static;
            justify-content: flex-end;
            width: 100%;
            margin-top: -0.2rem;
        }
    }
</style>
